def is_sms_text(text):
    t = text.lower()
    return ("credited with etb" in t or
            "has been credited" in t or
            "you have received etb" in t or
            "received etb" in t or
            "you have transferred etb" in t or
            "transferred etb" in t)

@bot.message_handler(func=lambda m: m.text and is_sms_text(m.text))
def handle_forwarded_sms(m):
    print(f"SMS received from {m.chat.id}: {m.text[:80]}")
    sms = parse_sms(m.text)
    if not sms:
        bot.send_message(ADMIN_ID, "SMS parse አልቻለም")
        return

    sms_amount = sms["amount"]
    sms_ref    = sms.get("ref")
    sms_date   = sms.get("date")
    sms_bank   = sms.get("bank")
    acct_last  = sms.get("acct_last")

    print(f"SMS parsed: bank={sms_bank} amount={sms_amount} ref={sms_ref}")

    if sms_bank == "CBE" and acct_last and acct_last != CBE_ACCOUNT_LAST:
        bot.send_message(ADMIN_ID, f"CBE account mismatch! ...{acct_last} vs ...{CBE_ACCOUNT_LAST}")
        return

    if not is_today(sms_date):
        bot.send_message(ADMIN_ID, f"SMS ዛሬ አይደለም! Date: {sms_date}")
        return

    if sms_ref and is_dup_ref(sms_ref):
        bot.send_message(ADMIN_ID, f"Duplicate ref: <code>{sms_ref}</code>")
        return

    payments = fb_get("payments") or {}
    sorted_payments = sorted(
        [(pid, p) for pid, p in payments.items() if p.get("status") == "pending"],
        key=lambda x: x[1].get("time", 0)
    )

    matched_pid = None
    matched_uid = None

    for pid, pay in sorted_payments:
        pay_ref = pay.get("ref", "")
        if sms_ref and pay_ref and pay_ref.upper() == sms_ref.upper():
            matched_pid = pid
            matched_uid = str(pay.get("user_id"))
            break

    if not matched_pid:
        for pid, pay in sorted_payments:
            if amounts_match(float(pay.get("amount", 0)), sms_amount):
                matched_pid = pid
                matched_uid = str(pay.get("user_id"))
                break

    if not matched_pid:
        sms_key = sms_ref.upper() if sms_ref else f"sms_{int(datetime.now().timestamp())}"
        fb_set(f"bot/pending_sms/{sms_key}", {
            "bank": sms_bank, "amount": sms_amount, "sender": sms.get("sender"),
            "ref": sms_ref, "date": sms_date, "saved_at": datetime.now().timestamp(),
        })
        bot.send_message(ADMIN_ID,
            f"📥 <b>SMS Saved — Screenshot ይጠብቃል</b>\n\n"
            f"🏦 {sms_bank}\n💰 {sms_amount} ብር\n"
            f"👤 {sms.get('sender')}\n📋 Ref: <code>{sms_ref}</code>")
        return

    do_approve(matched_pid, matched_uid, sms_amount, sms)

