def extract_ref_from_text(text):
    cbe_url = re.search(r'(?:cbe\.com\.et[:\d]*/[^\s]*?)(FT[A-Z0-9]{6,14})', text, re.IGNORECASE)
    if cbe_url:
        return cbe_url.group(1).upper()
    cbe_ref = re.search(r'\b(FT[A-Z0-9]{6,14})\b', text, re.IGNORECASE)
    if cbe_ref:
        return cbe_ref.group(1).upper()
    tel_ref = re.search(r'(?:transaction\s*number\s*(?:is)?\s*:?\s*)(DE[A-Z0-9]{6,12})', text, re.IGNORECASE)
    if tel_ref:
        return tel_ref.group(1).upper()
    tel_ref2 = re.search(r'\b(DE[A-Z0-9]{6,12})\b', text, re.IGNORECASE)
    if tel_ref2:
        return tel_ref2.group(1).upper()
    return None

