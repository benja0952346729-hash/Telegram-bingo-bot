def amounts_match(expected, actual):
    if expected == 0:
        return False
    return abs(expected - actual) / expected * 100 <= 5

def parse_cbe_sms(text):
    text = re.sub(r'\s+', ' ', text.strip())
    amt_m = re.search(r'(?:received ETB|credited with ETB|Credited with ETB)\s+([\d,]+\.?\d*)', text, re.IGNORECASE)
    if not amt_m:
        return None
    amount = float(amt_m.group(1).replace(',', ''))
    sender_m = re.search(r'from account [^\(]+\(([^)]+)\)', text)
    if not sender_m:
        sender_m = re.search(r'from ([A-Za-z ]+),?\s*on', text)
    sender = sender_m.group(1).strip() if sender_m else "Unknown"
    sms_date = extract_date(text)
    ref_m = re.search(r'Ref No ([A-Z0-9]+)', text, re.IGNORECASE)
    if ref_m:
        ref = ref_m.group(1).upper()
    else:
        url_ref = re.search(r'(?:cbe\.com\.et[:\d]*/[^\s]*?)(FT[A-Z0-9]{6,14})', text, re.IGNORECASE)
        ref = url_ref.group(1).upper() if url_ref else None
        if not ref:
            ft_ref = re.search(r'\b(FT[A-Z0-9]{6,14})\b', text, re.IGNORECASE)
            ref = ft_ref.group(1).upper() if ft_ref else None
    acct_m    = re.search(r'account 1\*+(\d{4})', text, re.IGNORECASE)
    acct_last = acct_m.group(1) if acct_m else None
    return {"bank": "CBE", "amount": amount, "sender": sender, "date": sms_date, "ref": ref, "acct_last": acct_last}

def parse_telebirr_sms(text):
    text = re.sub(r'\s+', ' ', text.strip())
    # "received ETB" ወይም "transferred ETB"
    amt_m = re.search(r'(?:received|transferred) ETB ([\d,]+\.?\d*)', text, re.IGNORECASE)
    if not amt_m:
        return None
    amount = float(amt_m.group(1).replace(',', ''))
    sender_m = re.search(r'from ([A-Za-z ]+?)(?:\([\d*]+\))?\s+on', text, re.IGNORECASE)
    if not sender_m:
        sender_m = re.search(r'from ([A-Za-z ]+(?:Bank|S\.?C\.?)?)', text, re.IGNORECASE)
    sender = sender_m.group(1).strip() if sender_m else "Unknown"
    sms_date = extract_date(text)
    # Telebirr transaction number (DE...) ወይም bank transaction number (FT...)
    ref = None
    de_ref = re.search(r'telebirr\s+transa?ction\s+number\s+is\s+([A-Z0-9]{8,14})', text, re.IGNORECASE)
    if de_ref:
        ref = de_ref.group(1).upper()
    if not ref:
        ft_ref = re.search(r'bank\s+transaction\s+number\s+is\s+(FT[A-Z0-9]{6,14})', text, re.IGNORECASE)
        if ft_ref:
            ref = ft_ref.group(1).upper()
    if not ref:
        ref_m = re.search(r'transaction\s*number\s*(?:is)?\s*:?\s*([A-Z0-9]{8,14})', text, re.IGNORECASE)
        ref = ref_m.group(1).upper() if ref_m else None
    return {"bank": "Telebirr", "amount": amount, "sender": sender, "date": sms_date, "ref": ref, "acct_last": None}

def extract_date(text):
    d1 = re.search(r'(\d{2}/\d{2}/\d{4})', text)
    if d1:
        return d1.group(1)
    d2 = re.search(r'(\d{4})-(\d{2})-(\d{2})', text)
    if d2:
        return f"{d2.group(3)}/{d2.group(2)}/{d2.group(1)}"
    return None

def parse_sms(text):
    text_lower = text.lower()
    if "credited with etb" in text_lower or "has been credited" in text_lower:
        return parse_cbe_sms(text)
    if ("you have received etb" in text_lower or
        "received etb" in text_lower or
        "you have transferred etb" in text_lower or
        "transferred etb" in text_lower):
        if "cbe" in text_lower or "1*" in text_lower:
            return parse_cbe_sms(text)
        return parse_telebirr_sms(text)
    return None

def is_today(date_str):
    if not date_str:
        return True
    try:
        sms_dt = datetime.strptime(date_str, "%d/%m/%Y")
        today  = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
        return abs((sms_dt - today).days) <= 1
    except Exception:
        return True

