def timeout_checker():
    while True:
        try:
            now_ts = datetime.now().timestamp()
            pending_sms_list = fb_get("bot/pending_sms") or {}
            for sms_key, sms_data in list(pending_sms_list.items()):
                if now_ts - sms_data.get("saved_at", 0) > MATCH_TIMEOUT:
                    fb_delete(f"bot/pending_sms/{sms_key}")
                    bot.send_message(ADMIN_ID,
                        f"⏰ <b>SMS Timeout</b>\n🏦 {sms_data.get('bank')}\n"
                        f"💰 {sms_data.get('amount')} ብር\n📋 Ref: <code>{sms_data.get('ref')}</code>")
            payments = fb_get("payments") or {}
            for pid, pay in list(payments.items()):
                if pay.get("status") != "pending":
                    continue
                if now_ts - pay.get("time", 0) / 1000 > MATCH_TIMEOUT:
                    uid     = str(pay.get("user_id"))
                    amount  = pay.get("amount", 0)
                    display = pay.get("display") or uid
                    fb_set(f"payments/{pid}/status", "cancelled")
                    fb_delete(f"temp/{uid}")
                    try:
                        bot.send_message(int(uid),
                            f"⏰ <b>Deposit Cancelled</b>\n💰 {amount} ብር\n\nSMS 5 ደቂቃ ውስጥ አልደረሰም\nእንደገና ሞክር ወይም Admin ያናግሩ @admin")
                    except Exception: pass
                    bot.send_message(ADMIN_ID,
                        f"⏰ <b>Screenshot Timeout</b>\n👤 {display} (<code>{uid}</code>)\n💰 {amount} ብር")
        except Exception as e:
            print(f"Timeout checker error: {e}")
        time.sleep(30)

threading.Thread(target=timeout_checker, daemon=True).start()

